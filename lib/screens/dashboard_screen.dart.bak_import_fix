  int readPostUserId(Map<String, dynamic> post) {
    return FitnessWallApi.asInt(
      post['UserId'] ??
          post['userId'] ??
          post['user_id'] ??
          post['OwnerId'] ??
          post['ownerId'],
    );
  }

  int readPostId(Map<String, dynamic> post) {
    return FitnessWallApi.asInt(
      post['PostId'] ??
          post['PostID'] ??
          post['postId'] ??
          post['postID'] ??
          post['post_id'] ??
          post['id'],
    );
  }

  String readPostOwnerName(Map<String, dynamic> post) {
    final name = FitnessWallApi.asString(
      post['Fullname'] ??
          post['fullname'] ??
          post['name'] ??
          post['Username'] ??
          post['username'],
    ).trim();

    if (name.isNotEmpty && name.toLowerCase() != 'null') {
      return name;
    }

    final fallbackName = FitnessWallApi.readPostName(post);

    if (fallbackName.trim().isNotEmpty &&
        fallbackName.trim().toLowerCase() != 'user') {
      return fallbackName;
    }

    return 'User';
  }

  String readLocalImagePath(Map<String, dynamic> post) {
    return FitnessWallApi.asString(
      post['imagePath'] ?? post['ImagePath'] ?? post['localImagePath'],
    );
  }

  bool hasBackendPostImage(Map<String, dynamic> post) {
    final value = FitnessWallApi.asString(
      post['HasPhoto'] ??
          post['hasPhoto'] ??
          post['has_photo'] ??
          post['PostImage'] ??
          post['postImage'] ??
          post['post_image'] ??
          post['Image'] ??
          post['image'],
    ).trim().toLowerCase();

    return value == '1' ||
        value == 'true' ||
        value == 'yes' ||
        value == 'image' ||
        value == 'photo' ||
        value.isNotEmpty && value != '0' && value != 'false' && value != 'null';
  }

