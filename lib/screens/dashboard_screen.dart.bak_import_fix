  Future<bool> loadFitnessWallPosts({bool showErrorMessage = false}) async {
    if (!mounted) return false;

    setState(() {
      isLoadingFitnessWall = true;
    });

    try {
      final result = await FitnessWallApi.getAllPosts();

      if (!mounted) return false;

      if (result['success'] == false) {
        setState(() {
          isLoadingFitnessWall = false;
        });

        if (showErrorMessage) {
          final message = FitnessWallApi.asString(result['message']);

          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text(
                message.isEmpty ? 'Failed to load Fitness Wall.' : message,
              ),
              backgroundColor: Colors.red,
            ),
          );
        }

        return false;
      }

      final posts = FitnessWallApi.extractPostList(
        result,
      ).where(FitnessWallApi.isPublicPost).toList();

      final hydratedPosts = await addUserDetailsToPosts(posts);

      if (!mounted) return false;

      setState(() {
        fitnessWallPosts = hydratedPosts;
        isLoadingFitnessWall = false;
      });

      return true;
    } catch (error) {
      if (!mounted) return false;

      setState(() {
        isLoadingFitnessWall = false;
      });

      if (showErrorMessage) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error loading Fitness Wall: $error'),
            backgroundColor: Colors.red,
          ),
        );
      }

      return false;
    }
  }

  Future<List<Map<String, dynamic>>> addUserDetailsToPosts(
    List<Map<String, dynamic>> posts,
  ) async {
    final List<Map<String, dynamic>> updatedPosts = [];

    for (final post in posts) {
      final updatedPost = Map<String, dynamic>.from(post);
      final userId = readPostUserId(updatedPost);

      if (userId > 0) {
        final profile = await getUserProfile(userId);

        final profileName = FitnessWallApi.asString(
          profile['Fullname'] ??
              profile['fullname'] ??
              profile['Username'] ??
              profile['username'] ??
              profile['name'],
        );

        if (profileName.trim().isNotEmpty) {
          updatedPost['name'] = profileName.trim();
          updatedPost['Fullname'] = profileName.trim();
        }
      }

      updatedPosts.add(updatedPost);
    }

    return updatedPosts;
  }

  Future<Map<String, dynamic>> getUserProfile(int userId) async {
    if (userProfileCache.containsKey(userId)) {
      return userProfileCache[userId] ?? {};
    }

    try {
      final result = await ApiClient.get('/profile/$userId');

      final profile = extractProfileMap(result);

      userProfileCache[userId] = profile;

      return profile;
    } catch (_) {
      return {};
    }
  }

  Map<String, dynamic> extractProfileMap(Map<String, dynamic> result) {
    final data = result['data'];

    if (data is Map) {
      return Map<String, dynamic>.from(data);
    }

    final profile = result['profile'];

    if (profile is Map) {
      return Map<String, dynamic>.from(profile);
    }

    final user = result['user'];

    if (user is Map) {
      return Map<String, dynamic>.from(user);
    }

    return result;
  }

